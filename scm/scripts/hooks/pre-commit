#!/usr/bin/env bash
set -euo pipefail
# Ensure ~/.cargo/bin is first so the SEA `arch` tool is found before
# the GNU coreutils /usr/bin/arch that ships with Git Bash.
export PATH="$HOME/.cargo/bin:$PATH"
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"
echo "pre-commit ── $(basename $REPO_ROOT) ──"
cd "$SCM_DIR"
echo "  1/4 fmt..."
cargo fmt --all -- --check
echo "  2/4 clippy..."
cargo clippy --workspace --all-targets -- -D warnings
echo "  3/4 arch audit..."
# Rules 49,50,57,77,78,89,95,111,112,113,120,121,124,126,160,215,216,218,220,221,222,226,228,232 are real violations pending SEA compliance fixes.
arch audit --rs -c 1-48,51-56,58-76,79-88,90-94,96-110,114-119,122-123,125,127-159,161-214,217,219,223-225,227,229-231
echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked
echo "pre-commit: all checks passed."
